# Generated by autoignore
# Templates: cpp meson ninja

# cpp
# @detect: *.cpp *.cc *.cxx *.c++ *.hpp *.hh
# C++ compiled object files
*.o
*.obj

# C++ compiled static libraries
*.a
*.lib

# C++ compiled shared libraries
*.so
*.so.*
*.dll
*.dylib

# C++ executables
*.exe
*.out
*.app

# Precompiled headers
*.gch
*.pch

# Debug information
*.pdb
*.idb

# Core dumps
core
core.*

# Temporary files
*.tmp
*.temp

# Backup files
*~
*.bak
*.orig

# Build directories (generic)
build/
bin/
obj/

# meson
# @detect: meson.build meson_options.txt
# Meson build directories
builddir/
build/

# Meson wrap files cache
subprojects/packagecache/
subprojects/*/

# Meson compile commands
compile_commands.json

# Meson private directory
.mesonpy-*

# ninja
# @detect: build.ninja
# Ninja build files
build.ninja
rules.ninja

# Ninja build logs
.ninja_log
.ninja_deps

# Ninja build directories
build/
out/

# Ninja generated files
*.ninja

